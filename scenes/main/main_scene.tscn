[gd_scene load_steps=2 format=3]

[ext_resource type="PackedScene" path="res://scenes/battle/battle_scene.tscn" id="1_battle"]

[sub_resource type="GDScript" id="GDScript_main_scene"]
script/source = "extends Node2D

@onready var _battle_scene = $BattleScene
@onready var _status_summary_label: Label = $StatusSummaryLabel
@onready var _settle_hint_label: Label = $SettleHintLabel

func _ready() -> void:
	_update_summary_labels()

func _process(_delta: float) -> void:
	_update_summary_labels()

func _update_summary_labels() -> void:
	if _battle_scene == null:
		return
	var controller = _battle_scene.get_node_or_null(\"BattleController\")
	if controller == null or not controller.has_method(\"get_state\"):
		return
	var state := str(controller.call(\"get_state\"))
	if _status_summary_label != null:
		if state == \"reward\":
			_status_summary_label.text = \"Status: Reward choice is ready\"
		elif state == \"settle\":
			_status_summary_label.text = \"Status: Settle reached, the run is over\"
		else:
			_status_summary_label.text = \"Status: Combat is running\"
	if _settle_hint_label != null:
		if state == \"settle\":
			_settle_hint_label.text = \"Restart the run after Settle to watch the loop again\"
		else:
			_settle_hint_label.text = \"Reward leads to the next wave; Settle ends the run\""

[node name="MainScene" type="Node2D"]
script = SubResource("GDScript_main_scene")

